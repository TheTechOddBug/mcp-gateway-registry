{
  "scope_name": "public-mcp-users",
  "description": "Users with access to public MCP servers (context7, cloudflare-docs) and flight-booking agent",
  "server_access": [
    {
      "server": "context7",
      "methods": ["initialize", "notifications/initialized", "ping", "tools/list", "tools/call", "resources/list", "resources/templates/list"],
      "tools": ["*"]
    },
    {
      "server": "/context7",
      "methods": ["initialize", "notifications/initialized", "ping", "tools/list", "tools/call", "resources/list", "resources/templates/list"],
      "tools": ["*"]
    },
    {
      "server": "/context7/",
      "methods": ["initialize", "notifications/initialized", "ping", "tools/list", "tools/call", "resources/list", "resources/templates/list"],
      "tools": ["*"]
    },
    {
      "server": "cloudflare-docs",
      "methods": ["initialize", "notifications/initialized", "ping", "tools/list", "tools/call", "resources/list", "resources/templates/list"],
      "tools": ["*"]
    },
    {
      "server": "/cloudflare-docs",
      "methods": ["initialize", "notifications/initialized", "ping", "tools/list", "tools/call", "resources/list", "resources/templates/list"],
      "tools": ["*"]
    },
    {
      "server": "/cloudflare-docs/",
      "methods": ["initialize", "notifications/initialized", "ping", "tools/list", "tools/call", "resources/list", "resources/templates/list"],
      "tools": ["*"]
    },
    {
      "server": "api",
      "methods": ["initialize", "GET", "POST", "servers", "agents", "search", "rating", "tools", "tokens"],
      "tools": []
    },
    {
      "server": "v0.1",
      "methods": ["agents", "GET", "POST"],
      "tools": []
    },
    {
      "agent": "/flight-booking",
      "actions": ["list_agents", "get_agent", "invoke_agent"]
    },
    {
      "agent": "/flight-booking-agent",
      "actions": ["list_agents", "get_agent", "invoke_agent"]
    }
  ],
  "group_mappings": ["public-mcp-users", "5f605d68-06bc-4208-b992-bb378eee12c5"],
  "ui_permissions": {
    "list_service": ["all"],
    "list_agents": ["/flight-booking", "/flight-booking-agent"],
    "get_agent": ["/flight-booking", "/flight-booking-agent"],
    "list_skills": ["all"]
  },
  "create_in_idp": true
}
