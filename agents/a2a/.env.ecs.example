# =============================================================================
# A2A sample agents (Travel Assistant + Flight Booking) - ECS / CloudFront config
# =============================================================================
# Variant of .env.example for the "hybrid" topology: the agents run on a host
# (this box) via deploy_local.sh, but register with and are discovered through a
# REMOTE registry/gateway deployed on ECS behind CloudFront. The gateway then
# reverse-proxies A2A traffic back to these agents.
#
# Usage: copy to .env (deploy_local.sh always sources .env), fill in, then run
# ./deploy_local.sh. For the purely-local docker-compose setup use .env.example
# instead (docker service-name URLs).
#
# Prerequisites for this topology (see the A2A egress trust-model docs):
#   - Registry deployed on ECS with A2A_REVERSE_PROXY_ENABLED=true.
#   - Register each agent with url = this host's PUBLIC backend
#     (e.g. http://<public-host>:9002/ for flight-booking, :9001 for travel);
#     the registry rewrites the advertised url to the CloudFront /agent/<path>/
#     and stores your backend in proxy_pass_url. See cli/examples/*_ecs.json.
#   - Open the agent ports (9001/9002) INBOUND from the ECS egress (NAT EIPs)
#     only -- not 0.0.0.0/0 -- so the ECS gateway can reach the agents.

# ----- Registry (agent discovery + card pull) -------------------------------
# PUBLIC CloudFront URL of the ECS registry (NOT a docker service name). The
# agents call its discovery API over the internet, so use https + the real host.
MCP_REGISTRY_URL=https://your-distribution.cloudfront.net

# ----- Registry authentication (choose ONE) ---------------------------------
# The token/creds MUST be valid against the ECS deployment's IdP, not a local
# Keycloak. Option 1: a JWT minted from the ECS registry (short-lived; fine for
# a one-off test). Option 2 (preferred for anything long-running): M2M client
# credentials registered in the ECS Keycloak realm; each agent refreshes its own.
REGISTRY_JWT_TOKEN=

TRAVEL_AGENT_M2M_CLIENT_ID=
TRAVEL_AGENT_M2M_CLIENT_SECRET=
FLIGHT_BOOKING_M2M_CLIENT_ID=
FLIGHT_BOOKING_M2M_CLIENT_SECRET=

# ----- Keycloak (inbound JWT validation on the agents) ----------------------
# The ECS deployment's PUBLIC Keycloak URL + realm, used to validate the bearer
# on inbound requests (when not running presence-only). For a quick test you can
# skip real validation with AGENT_AUTH_PRESENCE_ONLY=true below and leave these
# at any placeholder.
KEYCLOAK_URL=https://your-keycloak-host
KEYCLOAK_REALM=mcp-gateway

# ----- Agent auth mode (TEST/DEMO only) -------------------------------------
# Presence-only: accept any non-empty "Authorization: Bearer <anything>" WITHOUT
# verifying it against the realm. Useful for exercising the gateway end-to-end
# before wiring a real per-agent credential. NEVER enable in a real deployment
# (the agents bind on all interfaces to be reachable by the gateway). Set false
# and configure KEYCLOAK_URL/REALM for real validation.
AGENT_AUTH_PRESENCE_ONLY=true

# In this hybrid topology the agents bind on all interfaces so the ECS gateway
# can reach them, and presence-only is effectively unauthenticated, so the agent
# refuses to start unless you explicitly acknowledge that here. Required =true
# for this test setup; never use in production.
AGENT_AUTH_ALLOW_EXPOSED_PRESENCE_ONLY=true
