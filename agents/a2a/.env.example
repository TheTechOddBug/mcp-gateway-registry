# =============================================================================
# A2A sample agents (Travel Assistant + Flight Booking) - local Docker config
# =============================================================================
# Copy to .env and fill in. deploy_local.sh sources this before starting the
# containers on the registry's docker network (mcp-gateway-registry_default).

# ----- Registry (agent discovery + card pull) -------------------------------
# Base URL the agents use to call the registry's discovery/search API. On the
# shared docker network use the registry service name and its INTERNAL nginx
# port 8080 (the container does not listen on port 80). Do NOT use
# "http://registry" alone -- that resolves to :80 and connections are refused.
MCP_REGISTRY_URL=http://registry:8080

# ----- Registry authentication (choose ONE) ---------------------------------
# Option 1: direct JWT. Paste a valid token from the registry UI or API. Used
# verbatim for the registry discovery API; note tokens are short-lived, so for
# anything long-running prefer the M2M option below (auto-refreshed).
REGISTRY_JWT_TOKEN=

# Option 2: M2M client credentials (used when REGISTRY_JWT_TOKEN is empty). Each
# agent fetches + refreshes its own token from Keycloak.
TRAVEL_AGENT_M2M_CLIENT_ID=
TRAVEL_AGENT_M2M_CLIENT_SECRET=
FLIGHT_BOOKING_M2M_CLIENT_ID=
FLIGHT_BOOKING_M2M_CLIENT_SECRET=

# ----- Keycloak (inbound JWT validation on the agents) ----------------------
# The agents validate the bearer on incoming requests against this realm's JWKS.
# Use the service name on the docker network.
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=mcp-gateway

# ----- Agent auth mode (TEST/DEMO only) -------------------------------------
# Presence-only: accept any non-empty "Authorization: Bearer <anything>" WITHOUT
# verifying it against the realm. Only for exercising the gateway locally; never
# enable in a shared or internet-reachable deployment. Leave unset/false for
# real JWT validation. (docker-compose.local.yml defaults this to true for the
# local sandbox.)
AGENT_AUTH_PRESENCE_ONLY=false

# Presence-only is effectively unauthenticated, so the agent refuses to start
# in presence-only mode while binding to all interfaces (0.0.0.0/::) unless you
# explicitly opt in here. Set true ONLY for a throwaway gateway-passthrough test
# where the gateway reaches the agent over an exposed port; never in production.
AGENT_AUTH_ALLOW_EXPOSED_PRESENCE_ONLY=false
