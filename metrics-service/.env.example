# Metrics Service Configuration

# Service Settings
METRICS_SERVICE_PORT=8890
METRICS_SERVICE_HOST=0.0.0.0

# Database Settings (Container-based SQLite)
DATABASE_URL=sqlite:///var/lib/sqlite/metrics.db
SQLITE_DB_PATH=/var/lib/sqlite/metrics.db
METRICS_RETENTION_DAYS=90
DB_CONNECTION_TIMEOUT=30
DB_MAX_RETRIES=5

# OpenTelemetry Settings
OTEL_SERVICE_NAME=mcp-metrics-service
OTEL_PROMETHEUS_ENABLED=true
OTEL_PROMETHEUS_PORT=9465
OTEL_OTLP_ENDPOINT=http://jaeger:14250

# API Security
METRICS_RATE_LIMIT=1000
API_KEY_HASH_ALGORITHM=sha256

# REQUIRED: per-deployment secret used to pepper stored API-key hashes.
# The service refuses to start if this is unset, empty, weak, or shorter than
# 32 characters. Left unset on purpose -- generate a unique value per deployment
# and set it here (or in your environment):
#   openssl rand -hex 32
# Rotating this value invalidates all existing API-key hashes; re-issue keys
# after rotation (see docs). Do NOT reuse this value across deployments.
METRICS_KEY_PEPPER=

# Per-client-IP throttle for the unauthenticated /rate-limit lookup.
RATE_LIMIT_ENDPOINT_MAX_REQUESTS=10
RATE_LIMIT_ENDPOINT_WINDOW_SECONDS=60

# Performance Settings
BATCH_SIZE=100
FLUSH_INTERVAL_SECONDS=30
MAX_REQUEST_SIZE=10MB
